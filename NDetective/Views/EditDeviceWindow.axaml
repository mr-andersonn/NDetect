<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NDetective.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="400" Height="400"
        Title="{Binding WindowTitle}"
        Background="#1e1e1e"
        x:Class="NDetective.Views.EditDeviceWindow"
        x:DataType="vm:EditDeviceViewModel">
    
    <Grid RowDefinitions="Auto, *">
        <StackPanel HorizontalAlignment="Stretch"
                    Spacing="15"
                    Margin="16">
        
            <TextBlock Text="{Binding SelectedDeviceMac}" />
            <TextBlock Text="{Binding SelectedDeviceIp}" />
        
            <TextBlock Text="Name" />
            <TextBox Name="NameTextBox" />
            
            <TextBlock Text="Description" />
            <TextBox Name="DescriptionTextBox" Height="100"/>
            
            
        </StackPanel>
        <Button Grid.Row="1" Content="Update"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="16"/>
    </Grid> 

</Window>
