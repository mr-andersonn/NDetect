<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NDetective.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="NDetective.Views.SearchPageView"
             x:DataType="vm:SearchPageViewModel">

    <UserControl.Styles>
        <Style Selector="TextBlock.PageTitle">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
        </Style>

        <Style Selector="TextBlock.SectionTitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#B8B8B8"/>
        </Style>

        <Style Selector="Button.ActionButton">
            <Setter Property="Background" Value="#232323"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="BorderBrush" Value="#2F2F2F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style Selector="Button.ActionButton:pointerover">
            <Setter Property="Background" Value="#2B2B2B"/>
        </Style>

        <Style Selector="Border.PanelCard">
            <Setter Property="Background" Value="#171717"/>
            <Setter Property="BorderBrush" Value="#262626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style Selector="Border.DeviceRow">
            <Setter Property="Background" Value="#1D1D1D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style Selector="TextBlock.DeviceText">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid Margin="20" RowDefinitions="Auto,Auto,*,*" RowSpacing="16">

        <TextBlock Grid.Row="0"
                   Text="Search"
                   Classes="PageTitle"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="10">
            <Button Classes="ActionButton"
                    Command="{Binding ScanCommand}">
                Scan
            </Button>
            <Button Classes="ActionButton"
                    Command="{Binding StopCommand}">
                Stop
            </Button>
            <Button Classes="ActionButton"
                    Command="{Binding SaveCommand}">
                Save All
            </Button>
        </StackPanel>

        <Border Grid.Row="2" Classes="PanelCard">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock Text="Authorized devices"
                           Classes="SectionTitle"/>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Authorized}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="DeviceRow">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Device.Ip}"
                                                   Foreground="{Binding Foreground}"
                                                   Classes="DeviceText"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Device.Mac}"
                                                   Foreground="{Binding Foreground}"
                                                   Classes="DeviceText"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="3" Classes="PanelCard">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <TextBlock Text="Unauthorized devices"
                           Classes="SectionTitle"/>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Unauthorized}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="DeviceRow">
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Device.Ip}"
                                                   Foreground="{Binding Foreground}"
                                                   Classes="DeviceText"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Device.Mac}"
                                                   Foreground="{Binding Foreground}"
                                                   Classes="DeviceText"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

    </Grid>

</UserControl>